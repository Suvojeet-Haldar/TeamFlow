# Enter your code here. Read input from STDIN. Print output to STDOUT
n=int(input())
for i in range(1,n+1):
    s="H"*((2*i)-1)
    print(s.center(2*n-1," "))
    
for i in range(1,n+2):
    s="H"*n
    print(s.rjust(n+2," ")+s.rjust(n*4," "))
    
for i in range(1,n-1):
    s="H"*5*n
    print(s.rjust(5*n+2," "))
    
for i in range(1,n+2):
    s="H"*n
    print(s.rjust(n+2," ")+s.rjust(n*4," "))
    
for i in range(n,0):
    s="H"*((2*i)-1)
    print(s.rjust((n*6)-1," "))