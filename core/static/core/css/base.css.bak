  color: var(--text-secondary) !important;
  font-size: 0.88rem !important;
  line-height: 1.4 !important;
  word-break: break-word;
}

/* ── Kanban board: auto-width, no side scroll ── */
/* Remove overflow-x from wrapper */
.kanban-board,
.task-columns,
[class*="kanban"] {
  display: grid !important;
  grid-template-columns: repeat(4, 1fr) !important;
  gap: 16px !important;
  overflow-x: unset !important;
  width: 100% !important;
}

/* Responsive: stack on smaller screens */
@media (max-width: 860px) {
  .kanban-board,
  .task-columns,
  [class*="kanban"] {
    grid-template-columns: repeat(2, 1fr) !important;
  }
}
@media (max-width: 540px) {
  .kanban-board,
  .task-columns,
  [class*="kanban"] {
    grid-template-columns: 1fr !important;
  }
}

/* Kill the horizontal scrollbar container */
.kanban-scroll-wrapper,
.board-scroll,
[class*="scroll-x"] {
  overflow-x: unset !important;
}

/* ── Autofill: don't let browser yellow override dark inputs ── */
input:-webkit-autofill,
input:-webkit-autofill:hover,
input:-webkit-autofill:focus,
textarea:-webkit-autofill,
select:-webkit-autofill {
  -webkit-box-shadow: 0 0 0 1000px var(--bg-surface-2, #1a1c2e) inset !important;
  -webkit-text-fill-color: var(--text-primary, #e8eaf6) !important;
  caret-color: var(--text-primary, #e8eaf6);
  transition: background-color 5000s ease-in-out 0s;
}

